```
"icon": "./assets/images/icon.png",

"scheme": "gitapath",
"userInterfaceStyle": "dark",
"newArchEnabled": true,

"ios": {
  "supportsTablet": true,
  "bundleIdentifier": "com.gitapath.arjunai",
  "infoPlist": {
    "NSMicrophoneUsageDescription": "Record voice messages to Arjun AI",
    "NSSpeechRecognitionUsageDescription": "Convert speech to text for chat"
  }
},

"android": {
  "adaptiveIcon": {
    "foregroundImage": "./assets/images/adaptive-icon.png",
    "backgroundColor": "#0c0c0c"
  },
  "package": "com.gitapath.arjunai",
  "permissions": [
    "RECORD_AUDIO"
  ],
  "edgeToEdgeEnabled": true
},

"web": {
  "bundler": "metro",
  "output": "static",
  "favicon": "./assets/images/favicon.png"
},

"plugins": [
  "expo-router",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash-image.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#0c0c0c"
    }
  ]
],

"experiments": {
  "typedRoutes": true
}
